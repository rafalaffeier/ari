POSTGRES_DB=ai_assistant
POSTGRES_USER=ai_assistant
POSTGRES_PASSWORD=replace-with-a-generated-password
REDIS_PASSWORD=replace-with-a-generated-password

SECRET_KEY=replace-with-at-least-32-random-bytes
ALLOWED_ORIGINS=["https://staging.example.com","tauri://localhost"]
OPENAI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://staging.example.com/api/v1/auth/google/callback
DUFFEL_ACCESS_TOKEN=
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_API_VERSION=v2
DUFFEL_TEST_MODE=true
AI_MODEL=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.75

S3_BUCKET=ai-assistant-staging-sync
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-object-storage-secret-key

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
