ENV=local
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ai_assistant
REDIS_URL=redis://localhost:6380/0
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","tauri://localhost"]
OPENAI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
PUBLIC_APP_URL=http://localhost:8000
EMAIL_FROM=ARI <no-reply@ari.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
AI_MODEL=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.75
MEMORY_ROOT=data/memory
SYNC_STORAGE_ROOT=data/sync
SYNC_STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
